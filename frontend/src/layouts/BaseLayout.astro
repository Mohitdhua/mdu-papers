---
import '../styles/global.css';
import SEO from '@components/SEO.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import BackToTop from '@components/BackToTop.astro';
import AdBanner from '@components/AdBanner.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  publishedTime?: string;
}

const { title, description, image, type, noindex, jsonLd, publishedTime } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#4F46E5" />



    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
      publishedTime={publishedTime}
    />

    <!-- Apply theme before paint to avoid FOUC -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <style>
      .site-layout-wrapper {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 100%;
        max-width: 1600px;
        margin: 0 auto;
        gap: 1.5rem;
        padding-inline: 1rem;
      }

      .main-content-area {
        flex: 1;
        min-width: 0;
        max-width: 1200px;
      }

      .sidebar-ad {
        width: 160px;
        flex-shrink: 0;
        display: none;
      }

      .ad-sticky-container {
        position: sticky;
        top: 6rem;
      }

      @media (min-width: 1480px) {
        .sidebar-ad {
          display: block;
        }
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="mesh-bg" aria-hidden="true"></div>
    <Header />
    <main id="main-content">
      <div class="site-layout-wrapper">
        <aside class="sidebar-ad left-ad" aria-label="Sidebar Ad Left">
          <div class="ad-sticky-container">
            <AdBanner slot="left-skyscraper" label="Skyscraper Left" />
          </div>
        </aside>

        <div class="main-content-area">
          <slot />
        </div>

        <aside class="sidebar-ad right-ad" aria-label="Sidebar Ad Right">
          <div class="ad-sticky-container">
            <AdBanner slot="right-skyscraper" label="Skyscraper Right" />
          </div>
        </aside>
      </div>
    </main>
    <Footer />
    <BackToTop />

    <!-- Global download tracking: increments the counter via Supabase RPC. -->
    <script>
      // Expose a helper for the PdfViewer island.
      (window as any).__incrementDownload = async (paperId: number) => {
        try {
          const { supabase, isSupabaseConfigured } = await import('@lib/supabase');
          if (!isSupabaseConfigured || !supabase) return;
          await supabase.rpc('increment_download', { paper_id: paperId });
        } catch (e) {
          /* ignore */
        }
      };

      // Wire up direct download links.
      document.querySelectorAll<HTMLAnchorElement>('a[data-download]').forEach((link) => {
        link.addEventListener('click', () => {
          const id = Number(link.dataset.paperId);
          if (!Number.isNaN(id)) (window as any).__incrementDownload(id);
        });
      });
    </script>
  </body>
</html>
