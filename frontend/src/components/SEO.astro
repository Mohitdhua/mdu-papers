---
import { SITE, GA_ID } from '@lib/config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  /** Optional JSON-LD structured data object(s). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  publishedTime?: string;
  appendBrand?: boolean;
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
  type = 'website',
  noindex = false,
  jsonLd,
  publishedTime,
  appendBrand = true,
} = Astro.props;

const pageTitle = title || SITE.title;
const canonicalURL = new URL(Astro.url.pathname, SITE.url).href;
const ogImageURL = new URL(image, SITE.url).href;

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const gscToken = import.meta.env.PUBLIC_GSC_TOKEN || 'REPLACE_WITH_VERIFICATION_TOKEN';
const bingToken = import.meta.env.PUBLIC_BING_TOKEN;

const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// Always include a WebSite schema.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.brandName,
  url: SITE.url,
  description: SITE.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE.url}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<!-- Primary Meta Tags -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:site_name" content={SITE.brandName} />
<meta property="og:locale" content={SITE.locale} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Search console verification placeholder -->
<meta name="google-site-verification" content={gscToken} />
{bingToken && <meta name="msvalidate.01" content={bingToken} />}

<!-- Structured Data -->
{isHome && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
{
  jsonLdArray.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}

<!-- Google Analytics 4 -->
{
  GA_ID && !GA_ID.includes('XXXX') && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`} />
      <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_ID}');`} />
    </>
  )
}
