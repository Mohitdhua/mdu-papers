---
import { NAV_LINKS, SITE } from '@lib/config';
import ThemeToggle from './ThemeToggle.tsx';
import Icon from './Icon.astro';
import { getVisibleCourses } from '@lib/data';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

// Fetch visible courses for the 123apps-style dropdown megamenu
const courses = await getVisibleCourses();
const ugCourses = courses.filter((c) => c.degree_type?.toUpperCase() === 'UG').slice(0, 8);
const pgCourses = courses.filter((c) => c.degree_type?.toUpperCase() === 'PG').slice(0, 8);
const otherCourses = courses.filter((c) => {
  const type = c.degree_type?.toUpperCase();
  return type !== 'UG' && type !== 'PG';
}).slice(0, 8);
---

<header class="site-header">
  <div class="container">
    <a href="/" class="logo" aria-label={`${SITE.name} home`}>
      <span class="logo-mark" aria-hidden="true">🎓</span>
      <span class="logo-text">mdu<span>papers</span>.com</span>
    </a>

    <nav class="main-nav" aria-label="Primary">
      <a href="/" class="nav-item" aria-current={isActive('/') ? 'page' : undefined}>Home</a>
      
      <!-- 123apps-style Hover Dropdown Megamenu -->
      <div class="nav-dropdown-wrapper">
        <a href="/courses/" class="nav-item dropdown-trigger" aria-current={isActive('/courses/') ? 'page' : undefined}>
          Courses <Icon name="chevron-down" size={11} class="dropdown-chevron" />
        </a>
        <div class="nav-dropdown-content">
          <div class="dropdown-columns">
            <div class="dropdown-column">
              <h5>Undergraduate</h5>
              <ul>
                {ugCourses.map((c) => (
                  <li>
                    <a href={`/${c.slug}/`} title={`${c.name} Papers`}>{c.name}</a>
                  </li>
                ))}
              </ul>
            </div>
            <div class="dropdown-column">
              <h5>Postgraduate</h5>
              <ul>
                {pgCourses.map((c) => (
                  <li>
                    <a href={`/${c.slug}/`} title={`${c.name} Papers`}>{c.name}</a>
                  </li>
                ))}
              </ul>
            </div>
            <div class="dropdown-column">
              <h5>Others</h5>
              <ul>
                {otherCourses.map((c) => (
                  <li>
                    <a href={`/${c.slug}/`} title={`${c.name} Papers`}>{c.name}</a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>

      <a href="/blog/" class="nav-item" aria-current={isActive('/blog/') ? 'page' : undefined}>Blog</a>
      <a href="/contribute/" class="nav-item" aria-current={isActive('/contribute/') ? 'page' : undefined}>Contribute</a>
      <a href="/about/" class="nav-item" aria-current={isActive('/about/') ? 'page' : undefined}>About</a>
    </nav>

    <div class="header-actions">
      <a href="/search/" class="icon-btn" aria-label="Search papers">
        <Icon name="search" />
      </a>
      <ThemeToggle client:load />
      <button
        type="button"
        class="icon-btn mobile-menu-toggle"
        id="mobile-menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <Icon name="menu" />
      </button>
    </div>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile">
    {NAV_LINKS.map((link) => <a href={link.href}>{link.label}</a>)}
    <a href="/search/">Search</a>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const nav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });
</script>

<style>
  /* Base item spacing to match global.css */
  .nav-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    transition: var(--transition);
    text-decoration: none;
  }
  .nav-item:hover {
    color: var(--text-primary);
  }
  .nav-item[aria-current='page'] {
    color: #fff !important;
    background: var(--accent-primary);
    box-shadow: var(--shadow-sm);
  }

  /* Dropdown Wrapper & chevron rotation */
  .nav-dropdown-wrapper {
    position: relative;
    display: inline-block;
  }
  .dropdown-trigger {
    cursor: pointer;
  }
  .dropdown-chevron {
    transition: transform 0.2s ease;
  }
  .nav-dropdown-wrapper:hover .dropdown-chevron,
  .nav-dropdown-wrapper:focus-within .dropdown-chevron {
    transform: rotate(180deg);
  }

  /* Megamenu layout block */
  .nav-dropdown-content {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    z-index: 150;
    width: 600px;
    background-color: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: var(--space-5);
    display: none;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }

  /* Activate on hover or focus */
  .nav-dropdown-wrapper:hover .nav-dropdown-content,
  .nav-dropdown-wrapper:focus-within .nav-dropdown-content {
    display: block;
    opacity: 1;
    transform: translateX(-50%) translateY(6px);
    pointer-events: auto;
  }

  .dropdown-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .dropdown-column h5 {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--accent-primary);
    margin-bottom: var(--space-3);
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: var(--space-1.5);
    font-weight: 700;
  }

  .dropdown-column ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .dropdown-column a {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: var(--transition);
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 400;
  }

  .dropdown-column a:hover {
    color: var(--accent-primary);
    transform: translateX(3px);
  }
</style>
