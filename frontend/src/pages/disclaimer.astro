---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Icon from '@components/Icon.astro';
import { SITE } from '@lib/config';
---

<BaseLayout
  title="Disclaimer"
  description="Important disclaimer about MDU Papers. This is not the official website of Maharshi Dayanand University."
>
  <div class="container">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Disclaimer' }]} />

    <header class="page-header">
      <h1><Icon name="alert-triangle" /> Disclaimer</h1>
    </header>

    <div class="prose">
      <p>
        This website ({SITE.name}) is <strong>NOT</strong> the official website of Maharshi
        Dayanand University, Rohtak. This is an independent educational resource created to help
        students access previous year question papers for exam preparation.
      </p>
      <p>
        For official information, notifications, and results, please visit the official MDU
        website at
        <a href={SITE.universityUrl} target="_blank" rel="noopener noreferrer">mdu.ac.in</a>.
      </p>
      <p>
        All question papers are believed to be in the public domain. If you believe any content
        infringes on your copyright, please
        <a href="/contact/">contact us</a> and we will remove it promptly.
      </p>

      <h2>Accuracy of Content</h2>
      <p>
        While we strive to provide accurate and up-to-date papers, we make no guarantees about
        the completeness, accuracy or reliability of any paper. Always cross-check with official
        sources and your course material.
      </p>

      <h2>External Links</h2>
      <p>
        Our website may contain links to external sites. We are not responsible for the content
        or privacy practices of these third-party websites.
      </p>
    </div>
  </div>
</BaseLayout>
