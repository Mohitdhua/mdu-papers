---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Icon from '@components/Icon.astro';
import AdBanner from '@components/AdBanner.astro';
import CtaSection from '@components/CtaSection.astro';
import { SITE } from '@lib/config';
import {
  getVisibleCourses,
  getVisibleSubjectsByCourse,
  getSubjectsBySemester,
  getPapersBySubject,
} from '@lib/data';
import { semesterLabel, semesterToSlug, formatFileSize, ordinal } from '@lib/utils';
import { getAllBlogPosts } from '@lib/blog';

export async function getStaticPaths() {
  const courses = await getVisibleCourses();
  const paths = [];
  for (const course of courses) {
    const subjects = await getVisibleSubjectsByCourse(course.id);
    const semesters = [...new Set(subjects.map((s) => s.semester))].filter(
      (sem) => sem <= course.total_semesters
    );
    for (const sem of semesters) {
      paths.push({
        params: { course: course.slug, semester: semesterToSlug(sem) },
        props: { course, semester: sem },
      });
    }
  }
  return paths;
}

const { course, semester } = Astro.props;
const subjects = await getSubjectsBySemester(course.id, semester);

// Fetch all papers for each subject at build time
const subjectsWithPapers = await Promise.all(
  subjects.map(async (s) => {
    const papers = await getPapersBySubject(s.id);
    // Sort papers: newest first
    const sortedPapers = papers.sort((a, b) => b.year - a.year);
    return {
      ...s,
      papers: sortedPapers,
    };
  })
);

// Filter out subjects that don't have any papers uploaded
const visibleSubjects = subjectsWithPapers.filter((s) => s.papers.length > 0);
const totalPapers = visibleSubjects.reduce((sum, s) => sum + s.papers.length, 0);
const semLabel = semesterLabel(semester);

const subjectNames = visibleSubjects.map((s) => s.name).join(', ');
const semSlug = semesterToSlug(semester);

// Fetch internal linking assets: blogs and other courses
const allBlogPosts = await getAllBlogPosts();
const latestBlogs = allBlogPosts.slice(0, 3);

const allCourses = await getVisibleCourses();
const otherCourses = allCourses.filter((c) => c.id !== course.id).slice(0, 6);

// Rich FAQs for SEO Value
const faqs = [
  {
    question: `Which MDU ${course.name} ${semLabel} subjects have previous year question papers available?`,
    answer: `Question papers are available for MDU ${course.full_name} ${semLabel} subjects including: ${subjectNames || 'all core subjects taught in this semester'}. You can download the PDF files directly.`,
  },
  {
    question: `How can I download the MDU ${course.name} ${semLabel} exam papers?`,
    answer: `Simply scroll to the subject section on this page, find the year/session you want (e.g., Nov/Dec 2024), and click the "Download" button to save the PDF. You can also click "Preview" to read the paper online.`,
  },
  {
    question: `Are these MDU Rohtak ${course.name} previous year papers free?`,
    answer: `Yes, all previous year question papers and syllabus guides on this website are 100% free to download. There are no registration forms, ads overlay, or premium walls.`,
  },
  {
    question: `How does practicing previous year papers help in MDU semester exams?`,
    answer: `Practicing past papers is highly effective for MDU exams. It helps students understand the marking scheme, identify frequently repeated questions, and improve time management during the actual examination.`,
  },
];

// Google JSON-LD schema markup (CollectionPage, FAQPage, BreadcrumbList)
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${course.name} ${semLabel} Previous Year Papers`,
  description: `Download official previous year question papers (PDF) for MDU Rohtak ${course.full_name} ${semLabel} subjects.`,
  provider: {
    '@type': 'EducationalOrganization',
    name: SITE.university,
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE.url,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: course.name,
      item: `${SITE.url}/${course.slug}/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: semLabel,
      item: `${SITE.url}/${course.slug}/${semSlug}/`,
    },
  ],
};
---

<BaseLayout
  title={`MDU ${course.name} ${ordinal(semester)} Sem Previous Year Paper`}
  description={`Download free MDU Rohtak ${course.name} ${semesterLabel(semester)} previous year question papers PDF for ${subjectNames.slice(0, 50)}... Direct download, no ads!`}
  jsonLd={collectionJsonLd}
  appendBrand={false}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="container">
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: course.name, href: `/${course.slug}/` },
        { label: semLabel },
      ]}
    />

    <header class="page-header">
      <h1>
        <span aria-hidden="true">{course.icon_emoji}</span>
        {course.name} — {semLabel} Previous Year Papers
      </h1>
      <p>
        Download previous year question papers (PDF) for all MDU Rohtak {course.full_name} ({course.name}) {semLabel} subjects.
      </p>
      <div class="page-header-meta">
        <span><Icon name="book" size={14} /> {visibleSubjects.length} Subjects</span>
        <span><Icon name="file-text" size={14} /> {totalPapers} Papers</span>
      </div>
    </header>

    <!-- Subjects List and Papers (Option B Merge) -->
    <section class="section" style="padding-top: 1rem;">
      <h2 class="section-title"><Icon name="book-open" /> Available Subjects & Papers</h2>
      
      {
        visibleSubjects.length > 0 ? (
          <div class="subjects-list">
            {visibleSubjects.map((s) => (
              <div id={s.slug} class="card subject-section-card animate-in">
                <div class="subject-header">
                  <div>
                    <h3>{s.name} Question Papers</h3>
                    <p class="text-muted">MDU {course.name} {semLabel} Syllabus Subject — PYQs</p>
                  </div>
                  <span class="badge badge-success">{s.papers.length} Papers</span>
                </div>

                <div class="table-container">
                  <table class="papers-table">
                    <thead>
                      <tr>
                        <th>Exam Session</th>
                        <th>Year</th>
                        <th style="text-align: right;">Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      {s.papers.map((p) => (
                        <tr>
                          <td class="font-medium">{p.exam_session}</td>
                          <td>{p.year}</td>
                          <td style="text-align: right;">
                            <div class="actions-wrapper">
                              <button 
                                class="btn btn-secondary btn-sm preview-btn" 
                                data-url={p.pdf_url} 
                                data-title={`${s.name} — ${p.exam_session} ${p.year}`}
                              >
                                <Icon name="eye" size={13} /> Preview
                              </button>
                              <a href={p.pdf_url} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
                                <Icon name="download" size={13} /> Download
                              </a>
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <div class="empty-icon">📭</div>
            <h3>No papers uploaded yet</h3>
            <p class="text-muted">Question papers for this semester are being added. Check back shortly!</p>
          </div>
        )
      }
    </section>

    <!-- Semester Study Info (High SEO Value Content) -->
    <section class="section study-guide-intro">
      <div class="card intro-card">
        <h3>📚 Preparation Guide & Resources</h3>
        <p>
          Welcome to the study resource page for <strong>{course.full_name} ({course.name}) {semLabel}</strong> at Maharshi Dayanand University (MDU), Rohtak. 
          Practicing past exam papers is highly recommended by toppers to score high marks in MDU semester examinations. It gives you a clear understanding of the marking pattern, important sections, and question weightage.
        </p>
        <p>
          Below you will find a compiled year-wise list of question papers from <strong>2016 to 2024</strong>. You can click <strong>Preview</strong> to read the papers directly on your mobile or laptop, or click <strong>Download</strong> to save the PDF file offline.
        </p>
      </div>
    </section>

    <!-- FAQs Section (Rich Content) -->
    <section class="section">
      <h2 class="section-title"><Icon name="info" /> Frequently Asked Questions</h2>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <details class="faq-item card">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))
        }
      </div>
    </section>

    <!-- Strong Internal Linking: Other popular courses -->
    <section class="section">
      <h2 class="section-title"><Icon name="layers" /> Explore Other Courses</h2>
      <div class="courses-grid-compact">
        {otherCourses.map((c) => (
          <a href={`/${c.slug}/`} class="card course-link-card">
            <span aria-hidden="true" class="emoji">{c.icon_emoji}</span>
            <div class="details">
              <h4>{c.name}</h4>
              <p class="text-muted">MDU PYQs</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Strong Internal Linking: Latest Exam Guides / Blog Posts -->
    {latestBlogs.length > 0 && (
      <section class="section">
        <h2 class="section-title"><Icon name="file-text" /> MDU Exam Guides & Resources</h2>
        <div class="blogs-grid-compact">
          {latestBlogs.map((b) => (
            <a href={`/blog/${b.slug}/`} class="card blog-link-card">
              <h4>{b.title}</h4>
              <p class="text-muted">{b.description.slice(0, 100)}...</p>
              <span class="read-more-link">Read Prep Guide &rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <AdBanner slot="semester-bottom" />

    <CtaSection
      title="Need papers from another semester?"
      text={`Browse all ${course.name} semesters or search across every paper.`}
      primaryLabel={`All ${course.name} Semesters`}
      primaryHref={`/${course.slug}/`}
      primaryIcon="layers"
      secondaryLabel="Search Papers"
      secondaryHref="/search"
      secondaryIcon="search"
    />
  </div>

  <!-- Interactive PDF Preview Modal (Glassmorphism design) -->
  <div id="preview-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content-wrapper">
      <div class="modal-header">
        <h3 id="modal-title">Paper Preview</h3>
        <button id="close-modal" class="close-btn" aria-label="Close preview">&times;</button>
      </div>
      <div class="modal-body">
        <iframe id="modal-iframe" src="" title="PDF Preview"></iframe>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .intro-card {
    border-left: 4px solid var(--accent-primary);
    background-color: var(--bg-card);
  }
  .intro-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.15rem;
    color: var(--text-primary);
  }
  .intro-card p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }
  .intro-card p:last-child {
    margin-bottom: 0;
  }

  .subjects-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .subject-section-card {
    padding: 1.5rem;
    scroll-margin-top: 5rem; /* helps when jumping to anchor links */
  }
  .subject-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }
  .subject-header h3 {
    font-size: 1.25rem;
    font-weight: 600;
  }
  
  .table-container {
    overflow-x: auto;
  }
  .papers-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .papers-table th {
    text-align: left;
    padding: 0.5rem 1rem;
    color: var(--text-muted);
    font-weight: 500;
    border-bottom: 1px solid var(--border-color);
  }
  .papers-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-color);
  }
  .font-medium {
    font-weight: 500;
    color: var(--text-primary);
  }
  .actions-wrapper {
    display: inline-flex;
    gap: 0.5rem;
    justify-content: flex-end;
    width: 100%;
  }

  /* FAQs details tags */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .faq-item {
    padding: 1rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .faq-item[open] {
    border-color: var(--accent-primary);
  }
  .faq-item summary {
    font-weight: 500;
    outline: none;
    user-select: none;
  }
  .faq-item p {
    margin-top: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  /* Compact Grids for Internal Linking */
  .courses-grid-compact {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }
  .course-link-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .course-link-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-primary);
  }
  .course-link-card .emoji {
    font-size: 1.5rem;
  }
  .course-link-card h4 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .course-link-card p {
    font-size: 0.75rem;
  }

  .blogs-grid-compact {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .blog-link-card {
    padding: 1.25rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .blog-link-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-primary);
  }
  .blog-link-card h4 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }
  .blog-link-card p {
    font-size: 0.85rem;
    flex-grow: 1;
    margin-bottom: 1rem;
  }
  .read-more-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent-primary);
  }

  /* Modal styling */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1.5rem;
    animation: fadeIn 0.25s ease-out;
  }
  .modal-content-wrapper {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    width: 100%;
    max-width: 900px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }
  .modal-header h3 {
    font-size: 1.1rem;
    font-weight: 600;
  }
  .close-btn {
    background: none;
    border: none;
    font-size: 1.75rem;
    color: var(--text-muted);
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
  }
  .close-btn:hover {
    color: var(--text-primary);
  }
  .modal-body {
    height: 75vh;
  }
  .modal-body iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
</style>

<script>
  // Simple, robust client-side script to handle Modal previews
  const modal = document.getElementById('preview-modal');
  const iframe = document.getElementById('modal-iframe') as HTMLIFrameElement;
  const title = document.getElementById('modal-title');
  const closeBtn = document.getElementById('close-modal');

  if (modal && iframe && title && closeBtn) {
    // Open Modal
    document.querySelectorAll('.preview-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const url = (btn as HTMLElement).dataset.url || '';
        const paperTitle = (btn as HTMLElement).dataset.title || 'Paper Preview';
        
        iframe.src = url;
        title.textContent = paperTitle;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // prevent scrolling behind
      });
    });

    // Close Modal helper
    const closeModal = () => {
      modal.style.display = 'none';
      iframe.src = '';
      document.body.style.overflow = '';
    };

    closeBtn.addEventListener('click', closeModal);

    // Close on click outside modal content
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Close on Escape key press
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.style.display === 'flex') {
        closeModal();
      }
    });
  }
</script>
