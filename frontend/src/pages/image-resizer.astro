---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Icon from '@components/Icon.astro';
---

<BaseLayout
  title="Free Local Image Resizer — Resize & Convert Images Instantly"
  description="Resize, crop, and convert images completely locally in your browser. 100% private, secure, and ultra-fast. No files uploaded to any servers."
>
  <div class="container">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Image Resizer' }]} />

    <header class="page-header text-center">
      <h1><Icon name="layers" /> Free Local Image Resizer</h1>
      <p class="text-muted max-w-2xl mx-auto mt-2">
        Resize, compress, and convert your images (JPEG, PNG, WebP) completely locally in your browser. 
        Your files never touch any servers. 
      </p>
      <div class="security-badge">
        <Icon name="shield-check" size={16} />
        <span>100% Client-Side & Private</span>
      </div>
    </header>

    <div class="resizer-grid">
      <!-- Left Column: Input & Controls -->
      <div class="resizer-card card">
        <h2 class="card-title"><Icon name="file-text" size={18} /> 1. Upload Image</h2>
        
        <!-- Drag & Drop Zone -->
        <div class="dropzone" id="dropzone">
          <input type="file" id="file-input" accept="image/*" style="display: none;" />
          <div class="dropzone-content">
            <svg class="dropzone-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
              <circle cx="9" cy="9" r="2"/>
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
            </svg>
            <p class="dropzone-text">Drag and drop your image here, or <strong>browse files</strong></p>
            <span class="dropzone-sub">Supports JPEG, PNG, WebP</span>
          </div>
        </div>

        <div id="settings-panel" class="settings-panel disabled">
          <h2 class="card-title mt-6"><Icon name="filter" size={18} /> 2. Resize Settings</h2>
          
          <div class="settings-grid">
            <!-- Dimensions -->
            <div class="settings-row">
              <div class="input-group">
                <label for="width-input">Width (px)</label>
                <input type="number" id="width-input" min="1" disabled />
              </div>
              <div class="input-group">
                <label for="height-input">Height (px)</label>
                <input type="number" id="height-input" min="1" disabled />
              </div>
            </div>

            <!-- Aspect Ratio Lock -->
            <label class="checkbox-label">
              <input type="checkbox" id="lock-ratio" checked disabled />
              <span>Lock aspect ratio</span>
            </label>

            <!-- Output Format -->
            <div class="input-group">
              <label for="format-select">Convert to Format</label>
              <select id="format-select" disabled>
                <option value="image/jpeg">JPEG (.jpg)</option>
                <option value="image/png">PNG (.png)</option>
                <option value="image/webp" selected>WebP (.webp)</option>
              </select>
            </div>

            <!-- Quality Slider -->
            <div class="input-group" id="quality-group">
              <div class="slider-header">
                <label for="quality-slider">Image Quality</label>
                <span id="quality-val">85%</span>
              </div>
              <input type="range" id="quality-slider" min="1" max="100" value="85" disabled />
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Live Preview & Statistics -->
      <div class="resizer-card card">
        <h2 class="card-title"><Icon name="eye" size={18} /> 3. Preview & Status</h2>
        
        <div class="preview-area" id="preview-area">
          <div class="preview-placeholder">
            <p>Upload an image to see details & statistics</p>
          </div>
          <div class="preview-wrapper hidden" id="preview-wrapper">
            <img id="img-preview" alt="Image preview" />
          </div>
        </div>

        <!-- Statistics -->
        <div class="stats-panel hidden" id="stats-panel">
          <div class="stat-item">
            <span class="stat-name">Original Size:</span>
            <span class="stat-value" id="orig-size">-</span>
          </div>
          <div class="stat-item">
            <span class="stat-name">Original Dimensions:</span>
            <span class="stat-value" id="orig-dim">-</span>
          </div>
          <div class="stat-item highlight">
            <span class="stat-name">Estimated Resized Size:</span>
            <span class="stat-value text-accent" id="new-size">-</span>
          </div>
        </div>

        <!-- Actions -->
        <div class="actions-panel">
          <button type="button" id="resize-btn" class="btn btn-primary w-full disabled" disabled>
            <Icon name="download" size={18} /> Resize & Save Image
          </button>
          <button type="button" id="reset-btn" class="btn btn-secondary w-full mt-2 hidden">
            Reset Tool
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const dropzone = document.getElementById('dropzone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const settingsPanel = document.getElementById('settings-panel');
  const widthInput = document.getElementById('width-input') as HTMLInputElement;
  const heightInput = document.getElementById('height-input') as HTMLInputElement;
  const lockRatio = document.getElementById('lock-ratio') as HTMLInputElement;
  const formatSelect = document.getElementById('format-select') as HTMLSelectElement;
  const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
  const qualityVal = document.getElementById('quality-val');
  const previewArea = document.getElementById('preview-area');
  const previewWrapper = document.getElementById('preview-wrapper');
  const imgPreview = document.getElementById('img-preview') as HTMLImageElement;
  const statsPanel = document.getElementById('stats-panel');
  const origSize = document.getElementById('orig-size');
  const origDim = document.getElementById('orig-dim');
  const newSize = document.getElementById('new-size');
  const resizeBtn = document.getElementById('resize-btn') as HTMLButtonElement;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;

  let originalFile: File | null = null;
  let originalWidth = 0;
  let originalHeight = 0;
  let aspectRatio = 1;
  let originalImgSource = '';

  // Utility to format file size
  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }

  // Trigger file browser on click
  dropzone?.addEventListener('click', () => fileInput?.click());

  // Drag over states
  dropzone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('dragover');
  });

  dropzone?.addEventListener('dragleave', () => {
    dropzone.classList.remove('dragover');
  });

  dropzone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('dragover');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      handleImage(files[0]);
    }
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) {
      handleImage(fileInput.files[0]);
    }
  });

  // Handle uploaded image
  function handleImage(file: File) {
    if (!file.type.startsWith('image/')) {
      alert('Please upload an image file (JPEG, PNG, WebP).');
      return;
    }

    originalFile = file;
    const reader = new FileReader();
    reader.onload = (e) => {
      originalImgSource = e.target?.result as string;
      const img = new Image();
      img.onload = () => {
        originalWidth = img.width;
        originalHeight = img.height;
        aspectRatio = originalWidth / originalHeight;

        // Set inputs
        widthInput.value = originalWidth.toString();
        heightInput.value = originalHeight.toString();

        // Enable inputs
        enableControls(true);

        // Update preview
        imgPreview.src = originalImgSource;
        previewWrapper?.classList.remove('hidden');
        previewArea?.querySelector('.preview-placeholder')?.classList.add('hidden');

        // Update stats
        if (origSize) origSize.textContent = formatBytes(file.size);
        if (origDim) origDim.textContent = `${originalWidth} × ${originalHeight} px`;
        statsPanel?.classList.remove('hidden');
        resetBtn?.classList.remove('hidden');

        updateEstimatedSize();
      };
      img.src = originalImgSource;
    };
    reader.readAsDataURL(file);
  }

  function enableControls(enable: boolean) {
    if (enable) {
      settingsPanel?.classList.remove('disabled');
      widthInput.removeAttribute('disabled');
      heightInput.removeAttribute('disabled');
      lockRatio.removeAttribute('disabled');
      formatSelect.removeAttribute('disabled');
      qualitySlider.removeAttribute('disabled');
      resizeBtn.removeAttribute('disabled');
      resizeBtn.classList.remove('disabled');
    } else {
      settingsPanel?.classList.add('disabled');
      widthInput.setAttribute('disabled', 'true');
      heightInput.setAttribute('disabled', 'true');
      lockRatio.setAttribute('disabled', 'true');
      formatSelect.setAttribute('disabled', 'true');
      qualitySlider.setAttribute('disabled', 'true');
      resizeBtn.setAttribute('disabled', 'true');
      resizeBtn.classList.add('disabled');
    }
  }

  // Dimension inputs behavior (Maintain Aspect Ratio)
  widthInput?.addEventListener('input', () => {
    if (lockRatio.checked && widthInput.value) {
      const w = parseInt(widthInput.value, 10);
      if (w > 0) {
        heightInput.value = Math.round(w / aspectRatio).toString();
      }
    }
    updateEstimatedSize();
  });

  heightInput?.addEventListener('input', () => {
    if (lockRatio.checked && heightInput.value) {
      const h = parseInt(heightInput.value, 10);
      if (h > 0) {
        widthInput.value = Math.round(h * aspectRatio).toString();
      }
    }
    updateEstimatedSize();
  });

  formatSelect?.addEventListener('change', () => {
    const isLossless = formatSelect.value === 'image/png';
    const qualityGroup = document.getElementById('quality-group');
    if (isLossless) {
      qualityGroup?.classList.add('disabled');
      qualitySlider.setAttribute('disabled', 'true');
    } else {
      qualityGroup?.classList.remove('disabled');
      qualitySlider.removeAttribute('disabled');
    }
    updateEstimatedSize();
  });

  qualitySlider?.addEventListener('input', () => {
    if (qualityVal) qualityVal.textContent = `${qualitySlider.value}%`;
    updateEstimatedSize();
  });

  // Calculate and show estimated size based on quality & dimensions
  function updateEstimatedSize() {
    if (!originalFile) return;
    const targetWidth = parseInt(widthInput.value, 10) || originalWidth;
    const targetHeight = parseInt(heightInput.value, 10) || originalHeight;
    const format = formatSelect.value;
    const quality = parseFloat(qualitySlider.value) / 100;

    // A simple client-side mathematical model to estimate output file size
    const pixelsRatio = (targetWidth * targetHeight) / (originalWidth * originalHeight);
    let sizeFactor = 1;

    if (format === 'image/webp') {
      sizeFactor = 0.45 * (quality + 0.1); 
    } else if (format === 'image/jpeg') {
      sizeFactor = 0.7 * (quality + 0.15);
    } else {
      // PNG (lossless, can be larger if size changes but stays high fidelity)
      sizeFactor = 1.1; 
    }

    const estimatedBytes = originalFile.size * pixelsRatio * sizeFactor;
    // Cap estimation at original size if expanding to avoid showing weirdly inflated stats
    const finalBytes = Math.min(estimatedBytes, originalFile.size * pixelsRatio * 1.5);
    
    if (newSize) {
      newSize.textContent = `~ ${formatBytes(finalBytes)}`;
    }
  }

  // Trigger resize and local download
  resizeBtn?.addEventListener('click', () => {
    if (!originalImgSource) return;

    const targetWidth = parseInt(widthInput.value, 10);
    const targetHeight = parseInt(heightInput.value, 10);
    const format = formatSelect.value;
    const quality = parseInt(qualitySlider.value, 10) / 100;

    if (!targetWidth || !targetHeight) {
      alert('Please enter valid width and height values.');
      return;
    }

    resizeBtn.classList.add('loading');
    resizeBtn.textContent = 'Processing...';

    // Create canvas
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = targetWidth;
      canvas.height = targetHeight;
      const ctx = canvas.getContext('2d');

      if (ctx) {
        // Draw resized image
        ctx.drawImage(img, 0, 0, targetWidth, targetHeight);

        // Export & download
        canvas.toBlob((blob) => {
          if (blob) {
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            
            // Format file extension
            let ext = 'webp';
            if (format === 'image/jpeg') ext = 'jpg';
            if (format === 'image/png') ext = 'png';

            const baseName = originalFile ? originalFile.name.split('.')[0] : 'resized';
            a.download = `${baseName}_resized.${ext}`;
            a.href = url;
            a.click();
            URL.revokeObjectURL(url);
          } else {
            alert('Failed to generate image. Please try again.');
          }

          resizeBtn.classList.remove('loading');
          resizeBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg> Resize & Save Image`;
        }, format, quality);
      }
    };
    img.src = originalImgSource;
  });

  // Reset tool state
  resetBtn?.addEventListener('click', () => {
    originalFile = null;
    originalWidth = 0;
    originalHeight = 0;
    aspectRatio = 1;
    originalImgSource = '';
    fileInput.value = '';
    widthInput.value = '';
    heightInput.value = '';

    enableControls(false);

    imgPreview.src = '';
    previewWrapper?.classList.add('hidden');
    previewArea?.querySelector('.preview-placeholder')?.classList.remove('hidden');

    statsPanel?.classList.add('hidden');
    resetBtn?.classList.add('hidden');
  });
</script>

<style>
  .security-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: color-mix(in srgb, var(--accent-success) 12%, transparent);
    color: var(--accent-success);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-top: 1rem;
  }

  .resizer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .resizer-grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  .resizer-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }

  /* Dropzone */
  .dropzone {
    border: 2px dashed var(--glass-border);
    background: color-mix(in srgb, var(--bg-secondary) 40%, transparent);
    border-radius: var(--radius-lg);
    padding: 2.5rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: var(--transition);
  }

  .dropzone:hover, .dropzone.dragover {
    border-color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 4%, transparent);
    box-shadow: 0 0 20px color-mix(in srgb, var(--accent-primary) 10%, transparent);
  }

  .dropzone-icon {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    transition: var(--transition);
  }

  .dropzone:hover .dropzone-icon {
    color: var(--accent-primary);
    transform: translateY(-2px);
  }

  .dropzone-text {
    font-size: var(--text-sm);
    color: var(--text-primary);
  }

  .dropzone-sub {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  /* Settings */
  .settings-panel {
    transition: var(--transition);
  }

  .settings-panel.disabled {
    opacity: 0.4;
    pointer-events: none;
  }

  .settings-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .settings-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .input-group.disabled {
    opacity: 0.5;
  }

  .input-group label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-secondary);
  }

  .input-group input[type="number"],
  .input-group select {
    background: var(--bg-primary);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: 0.6rem 0.8rem;
    color: var(--text-primary);
    font-size: var(--text-sm);
    transition: var(--transition);
    width: 100%;
  }

  .input-group input[type="number"]:focus,
  .input-group select:focus {
    border-color: var(--accent-primary);
    outline: none;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-primary) 15%, transparent);
  }

  .checkbox-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: var(--text-sm);
    user-select: none;
    color: var(--text-primary);
  }

  .checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--accent-primary);
  }

  /* Range Slider */
  .slider-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .slider-header span {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--accent-primary);
  }

  input[type="range"] {
    width: 100%;
    accent-color: var(--accent-primary);
    height: 6px;
    border-radius: var(--radius-full);
  }

  /* Preview Area */
  .preview-area {
    border: 1px solid var(--glass-border);
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    min-height: 240px;
    max-height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 1rem;
    position: relative;
  }

  .preview-placeholder {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    text-align: center;
  }

  .preview-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-wrapper img {
    max-width: 100%;
    max-height: 320px;
    object-fit: contain;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  /* Stats */
  .stats-panel {
    background: color-mix(in srgb, var(--bg-secondary) 50%, transparent);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: 1rem;
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .stat-item {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-xs);
  }

  .stat-name {
    color: var(--text-secondary);
  }

  .stat-value {
    font-weight: 600;
    color: var(--text-primary);
  }

  .stat-item.highlight {
    border-top: 1px solid var(--glass-border);
    padding-top: 0.6rem;
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .text-accent {
    color: var(--accent-primary);
  }

  /* Actions */
  .actions-panel {
    margin-top: 1.5rem;
  }

  .btn.disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  .btn.loading {
    pointer-events: none;
    opacity: 0.8;
  }
</style>
