---
import BaseLayout from '@layouts/BaseLayout.astro';
import SearchBar from '@components/SearchBar.tsx';
import CourseCard from '@components/CourseCard.astro';
import AdBanner from '@components/AdBanner.astro';
import DisclaimerBanner from '@components/DisclaimerBanner.astro';
import Icon from '@components/Icon.astro';
import { getVisibleCourses, getRecentPapers, getSiteStats } from '@lib/data';
import { getAllBlogPosts } from '@lib/blog';
import { formatFileSize } from '@lib/utils';

const courses = await getVisibleCourses();
const ugCourses = courses.filter((c) => c.degree_type === 'UG');
const pgCourses = courses.filter((c) => c.degree_type === 'PG');
const recentPapers = await getRecentPapers(8);
const stats = await getSiteStats();

// Latest blog posts (DB + markdown merged).
const posts = (await getAllBlogPosts()).slice(0, 2);
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-content">
      <h1>
        Your One-Stop Hub for<br />
        <span class="hero-gradient-text">MDU Exam Papers</span>
      </h1>
      <p>
        Access {stats.papers}+ previous year papers for all courses, completely free.
      </p>
      <div class="hero-search">
        <SearchBar client:idle />
      </div>
    </div>
  </section>

  <div class="container">
    <!-- ALL COURSES (directory-style with UG/PG toggle) -->
    <section class="section" style="padding-top: var(--space-10);">
      {
        courses.length === 0 ? (
          <div class="empty-state">
            <div class="empty-icon">📚</div>
            <h3>Papers coming soon</h3>
            <p class="text-muted">
              We're adding question papers right now. Check back shortly, or use search to
              look for a specific paper.
            </p>
            <a href="/search" class="btn btn-primary mt-8">Search Papers</a>
          </div>
        ) : (
          <>
            <div class="course-tabs" role="tablist" aria-label="Course level">
              <button class="course-tab active" role="tab" data-tab="ug" aria-selected="true">
                <Icon name="book-open" size={16} /> Undergraduate ({ugCourses.length})
              </button>
              <button class="course-tab" role="tab" data-tab="pg" aria-selected="false">
                <Icon name="graduation-cap" size={16} /> Postgraduate ({pgCourses.length})
              </button>
            </div>

            <div id="home-panel-ug" class="course-panel">
              <div class="grid grid-cols-2 grid-cols-4">
                {ugCourses.map((course) => <CourseCard course={course} />)}
              </div>
            </div>

            <div id="home-panel-pg" class="course-panel" hidden>
              <div class="grid grid-cols-2 grid-cols-4">
                {pgCourses.map((course) => <CourseCard course={course} />)}
              </div>
            </div>
          </>
        )
      }
    </section>

    <AdBanner slot="home-mid" />

    <!-- RECENTLY ADDED -->
    <section class="section">
      <h2 class="section-title"><Icon name="clock" /> Recently Added Papers</h2>
      <div class="grid grid-cols-1 grid-cols-2">
        {
          recentPapers.map((rp) => (
            <a href={rp.url} class="card subject-card animate-in">
              <div class="subject-card-main">
                <h3 style="font-size: 1rem;">
                  {rp.course.name} — {rp.subject.name}
                </h3>
                <div class="subject-card-meta">
                  <span class="badge badge-secondary">{rp.paper.exam_session} {rp.paper.year}</span>
                  <span><Icon name="layers" size={14} /> {formatFileSize(rp.paper.pdf_size_kb)}</span>
                </div>
              </div>
              <Icon name="chevron-right" size={18} class="text-muted" />
            </a>
          ))
        }
      </div>
    </section>

    <!-- BLOG -->
    {
      posts.length > 0 && (
        <section class="section">
          <div class="section-header">
            <h2 class="section-title"><Icon name="file-text" /> From Our Blog</h2>
            <a href="/blog" class="course-card-link">All posts <Icon name="arrow-right" size={16} /></a>
          </div>
          <div class="grid grid-cols-2">
            {posts.map((post) => (
              <a href={`/blog/${post.slug}`} class="card blog-card animate-in">
                <div class="blog-card-tags">
                  {post.tags?.slice(0, 2).map((t) => <span class="badge">{t}</span>)}
                </div>
                <h3>{post.title}</h3>
                <p class="blog-card-excerpt">{post.description}</p>
                <div class="blog-card-meta">
                  <span><Icon name="calendar" size={12} /> {post.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <DisclaimerBanner />
  </div>
</BaseLayout>

<script>
  // Homepage UG/PG course toggle
  const tabs = document.querySelectorAll<HTMLButtonElement>('.course-tab');
  const panels = {
    ug: document.getElementById('home-panel-ug'),
    pg: document.getElementById('home-panel-pg'),
  };
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const key = tab.dataset.tab as 'ug' | 'pg';
      panels.ug?.toggleAttribute('hidden', key !== 'ug');
      panels.pg?.toggleAttribute('hidden', key !== 'pg');
    });
  });
</script>
